root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[.git/**]
indent_size = 8
indent_style = tab

[*.py]
indent_size = 4

[*.go]
indent_size = 8
indent_style = tab

[*.md]
# support hard line-breaks, 2 spaces at EOL:
trim_trailing_whitespace = false

[*.html]
indent_size = 4

[*.css]
indent_size = 4
indent_style = space

